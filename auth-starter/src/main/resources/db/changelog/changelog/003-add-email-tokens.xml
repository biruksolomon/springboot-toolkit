<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="004-add-email-tokens" author="auth-core">
        <createTable tableName="auth_email_tokens">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="token" type="varchar(500)" remarks="Base64 encoded token">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="type" type="varchar(20)" defaultValue="VERIFICATION">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false" foreignKeyName="fk_email_tokens_user" references="auth_users(id)"/>
            </column>
            <column name="expires_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="used_at" type="timestamp"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="auth_email_tokens" indexName="idx_email_tokens_token">
            <column name="token"/>
        </createIndex>

        <createIndex tableName="auth_email_tokens" indexName="idx_email_tokens_user">
            <column name="user_id"/>
        </createIndex>

        <createIndex tableName="auth_email_tokens" indexName="idx_email_tokens_expires">
            <column name="expires_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
